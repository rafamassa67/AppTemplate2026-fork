<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/text_dashboard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Cadastro de administrador"
        android:textAlignment="center"
        android:textColor="@color/primary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- IMAGEM -->
    <ImageView
        android:id="@+id/image_item"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:contentDescription="Store Photo"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_camera"
        app:layout_constraintTop_toBottomOf="@id/text_dashboard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:background="@drawable/image_border"
        android:padding="8dp"
        />

    <!-- BOTÃO IMAGEM -->
    <Button
        android:id="@+id/button_select_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecionar Imagem"
        android:backgroundTint="@color/card"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toBottomOf="@id/image_item"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- NOME -->
    <EditText
        android:id="@+id/nomeRelogio"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:hint="Nomeie o seu administrador de tempo"
        android:background="@drawable/input_bg_white"
        android:textColor="#000000"
        android:textColorHint="#777777"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/button_select_image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <!-- TEMPO -->
    <EditText
        android:id="@+id/tempoAdministrador"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:hint="Tempo limite (em minutos)"
        android:inputType="number"
        android:background="@drawable/input_bg_white"
        android:textColor="#000000"
        android:textColorHint="#777777"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/nomeRelogio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- DESCRIÇÃO -->
    <EditText
        android:id="@+id/adminDescription"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:hint="Descrição do limitador"
        android:background="@drawable/input_bg_white"
        android:textColor="#000000"
        android:textColorHint="#777777"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/tempoAdministrador"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- BOTÃO SALVAR -->
    <Button
        android:id="@+id/salvarItemButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Salvar"
        android:textStyle="bold"
        android:backgroundTint="@color/primary"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/adminDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>